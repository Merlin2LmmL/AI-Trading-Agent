# ── Free API Keys (register once, no payment needed) ─────────────────────────
# https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# https://newsapi.org/register
NEWSAPI_API_KEY=your_newsapi_api_key_here

# ── Ollama Configuration ──────────────────────────────────────────────────────
# Ollama runs locally — no API key needed.
# Make sure Ollama is running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434

# Stage 1: Fast extraction (Gemma 4 MoE — only 8B active params)
STAGE1_MODEL=gemma4

# Stage 2 + 3: Deep reasoning (DeepSeek-R1 70B — GPU+RAM split)
# Tune OLLAMA_NUM_GPU_LAYERS in /etc/systemd/system/ollama.service
# Start at 20, increase if no OOM errors. 0 = CPU only.
STAGE2_MODEL=deepseek-r1:70b
STAGE3_MODEL=deepseek-r1:70b

# GPU layers per stage (prevents VRAM overflow)
STAGE1_NUM_GPU_LAYERS=45
STAGE2_NUM_GPU_LAYERS=20
STAGE3_NUM_GPU_LAYERS=20

# ── General Settings ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=output

# ── Portfolio Mode ────────────────────────────────────────────────────────────
# real     = use actual holdings from config/portfolio.yaml
# paper    = simulated portfolio starting from PAPER_PORTFOLIO_VALUE
PORTFOLIO_MODE=paper
PAPER_PORTFOLIO_VALUE=100000
