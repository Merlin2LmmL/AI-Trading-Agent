# ── API Credentials (External) ───────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here
NEWSAPI_API_KEY=your_newsapi_api_key_here

# ── LLM Settings ──────────────────────────────────────────────────────────────
LLM_PROVIDER=api  # Options: api (Gemini), local (Ollama)

# --- API Models (Cloud) ---
API_STAGE1_MODEL=gemini-3.1-flash-lite-preview
API_STAGE2_MODEL=gemini-3.1-flash-lite-preview
API_STAGE3_MODEL=gemini-3-flash-preview
API_STAGE5_MODEL=gemini-3-flash-preview

# --- Local Models (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_STAGE1_MODEL=gemma4:latest
LOCAL_STAGE2_MODEL=qwen3:32b
LOCAL_STAGE3_MODEL=qwen3:32b
LOCAL_STAGE5_MODEL=deepseek-r1:70b

# ── Hardware & Memory ─────────────────────────────────────────────────────────
# Layer offloading for local models
STAGE1_NUM_GPU_LAYERS=-1
STAGE2_NUM_GPU_LAYERS=45
STAGE3_NUM_GPU_LAYERS=45
STAGE5_NUM_GPU_LAYERS=20

# ── Transcription ─────────────────────────────────────────────────────────────
# Options: google (multimodal, use Gemini for URLs), whisper (local whisper.cpp)
TRANSCRIPTION_PROVIDER=google
WHISPER_MODEL_SIZE=base

# ── System Settings ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORTFOLIO_MODE=paper
PAPER_PORTFOLIO_VALUE=100000
