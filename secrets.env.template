# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Wikifolio Account ─────────────────────────────────────────────────────────
# Used to fetch your current holdings for research
WIKIFOLIO_EMAIL=your_wikifolio_email@example.com
WIKIFOLIO_PASSWORD=your_wikifolio_password
# Short name from URL: wikifolio.com/de/de/w/wfni000gpt -> WIKIFOLIO_NAME=wfni000gpt
WIKIFOLIO_NAME=your_wikifolio_short_name

# ── Notifications (Optional) ──────────────────────────────────────────────────
NOTIFY_EMAILS=recipient1@example.com,recipient2@example.com

# ── Email Sender (SMTP via Gmail App Password) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your_gmail@gmail.com
